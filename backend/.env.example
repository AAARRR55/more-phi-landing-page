# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/morephi_store
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/morephi_store_test

# Auth
JWT_SECRET=change-me-to-32-plus-random-bytes-hex-or-base64
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
BCRYPT_COST=12

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=http://localhost:3000/checkout/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:3000/cancel

# CORS / Rate limiting
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MS=60000
CHECKOUT_RATE_LIMIT_MAX=6
CHECKOUT_RATE_LIMIT_WINDOW_MS=60000
ACTIVATION_RATE_LIMIT_MAX=20
ACTIVATION_RATE_LIMIT_WINDOW_MS=60000

# Licensing
LICENSE_KEY_PREFIX=MP
LICENSE_MAX_ACTIVATIONS=3
LICENSE_SIGNING_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMC4CAQAwBQYDK2VwBCIEIL...\n-----END PRIVATE KEY-----
LICENSE_SIGNING_KEY_ID=prod-ed25519-2026-01

# Email
EMAIL_PROVIDER=console
EMAIL_FROM=orders@morephi.example
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Downloads / CDN
DOWNLOAD_URL_BASE=https://cdn.morephi.example/more-phi/
